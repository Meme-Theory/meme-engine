# NASA MCP Server Configuration
# =============================
# Copy this file to .env and configure your settings

# ========== API Configuration ==========
# NASA API Key - Get yours at https://api.nasa.gov/
# DEMO_KEY has limited rate limits (30 requests/hour, 50/day)
API_KEY=DEMO_KEY

# API Base URLs (usually no need to change)
BASE_URL=https://api.nasa.gov
EPIC_BASE_URL=https://epic.gsfc.nasa.gov/EPIC/api

# ========== Cache Settings ==========
# Cache duration for images (in seconds) - 30 minutes default
CACHE_TTL_IMAGES=1800

# Cache duration for dynamic data (in seconds) - 10 minutes default
CACHE_TTL_DYNAMIC=600

# ========== Server Settings ==========
# Server name for identification
SERVER_NAME=NASA MCP Server

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Default number of items to return
DEFAULT_COUNT=10

# ========== Rate Limiting ==========
# Maximum API calls per hour for registered keys
MAX_HOURLY_CALLS=1000

# Maximum API calls per hour for DEMO_KEY
DEMO_HOURLY_LIMIT=30

# ========== Transport Settings ==========
# Transport type: stdio (default) or http
TRANSPORT=stdio

# Port for HTTP transport (only used when TRANSPORT=http)
PORT=8000